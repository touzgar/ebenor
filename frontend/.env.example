# ============================================
# FULL STACK NEXT.JS - Environment Configuration  
# ============================================
# Copy this file to .env.local and fill in your actual values
# ============================================

# ============================================
# PUBLIC VARIABLES (Exposed to Browser)
# ============================================
# Note: Do NOT put sensitive data in NEXT_PUBLIC_ variables!

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp Business Number
# Format: +216XXXXXXXX (include country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ============================================
# MONGODB DATABASE (Required - Server Only)
# ============================================
# For local development:
# MONGODB_URI=mongodb://localhost:27017/ebenor-creation
#
# For production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ebenor-creation?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ebenor-creation

# ============================================
# JWT AUTHENTICATION (Required - Server Only)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ============================================
# CLOUDINARY - Image/Video Upload (Required - Server Only)
# ============================================
# Sign up at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# EMAIL CONFIGURATION (Required - Server Only)
# ============================================
# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@ebenor-creation.com
ADMIN_EMAIL=admin@ebenor-creation.com

# ============================================
# SECURITY SETTINGS (Optional - Server Only)
# ============================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# DEVELOPMENT vs PRODUCTION
# ============================================
# Development (.env.local):
# - NEXT_PUBLIC_SITE_URL=http://localhost:3000
# - MONGODB_URI=mongodb://localhost:27017/ebenor-creation
#
# Production (Vercel Environment Variables):
# - NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# - MONGODB_URI=mongodb+srv://... (MongoDB Atlas)
# - Use strong passwords and secrets
# ============================================
